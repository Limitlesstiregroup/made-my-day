# Made My Day runtime configuration

# GA readiness (required for release:check)
MADE_MY_DAY_ONCALL_PRIMARY=
MADE_MY_DAY_ONCALL_PRIMARY_FILE=
MADE_MY_DAY_ESCALATION_DOC_URL=
MADE_MY_DAY_ESCALATION_DOC_URL_FILE=

# Optional admin protection + rotation
MADE_MY_DAY_ADMIN_TOKEN=
MADE_MY_DAY_ADMIN_TOKEN_FILE=
MADE_MY_DAY_ADMIN_TOKEN_PREVIOUS=
MADE_MY_DAY_ADMIN_TOKEN_PREVIOUS_FILE=

# API hardening
TRUST_PROXY=false
MAX_BODY_BYTES=16384
MAX_URL_CHARS=2048
ALLOWED_HOSTS=
REQUEST_TIMEOUT_MS=30000
HEADERS_TIMEOUT_MS=15000
KEEP_ALIVE_TIMEOUT_MS=5000

# Abuse/idempotency guardrails
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_MUTATIONS=120
RATE_LIMIT_MAX_KEYS=10000
IDEMPOTENCY_TTL_MS=86400000
MAX_IDEMPOTENCY_KEYS=5000
# GA bounds: IDEMPOTENCY_TTL_MS min 60000 max 604800000; MAX_IDEMPOTENCY_KEYS min 100 max 200000

# Content bounds
MAX_STORY_CHARS=5000
MAX_COMMENT_CHARS=300
MAX_COMMENTS_PER_STORY=500
MAX_AUTHOR_CHARS=60

# Data retention bounds
MAX_STORIES=5000
MAX_COMMENTS=20000
MAX_HALL_OF_FAME=520
MAX_GIFT_CARDS=520

# Import/runtime controls
IMPORT_TIMEOUT_MS=10000
PORT=4300
